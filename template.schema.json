{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TeamClaw Template",
  "type": "object",
  "required": ["id", "name", "version", "author", "description", "tags", "agents"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique template identifier in kebab-case"
    },
    "name": {
      "type": "string",
      "maxLength": 60,
      "description": "Human-readable template name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "author": {
      "type": "string",
      "description": "Template author"
    },
    "description": {
      "type": "string",
      "maxLength": 200,
      "description": "Short description of what this template does"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 5,
      "description": "Searchable tags"
    },
    "defaultGoalTemplate": {
      "type": "string",
      "description": "Default goal template with {placeholders}"
    },
    "estimatedCostPerRun": {
      "type": "number",
      "description": "Estimated cost in USD per run"
    },
    "minRuns": {
      "type": "integer",
      "description": "Recommended minimum number of runs"
    },
    "requiresWebhook": {
      "type": "boolean",
      "description": "Whether this template requires webhook configuration"
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/TemplateAgent" },
      "description": "Agent team configuration"
    }
  },
  "definitions": {
    "TemplateAgent": {
      "type": "object",
      "required": ["role"],
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "description": "Agent role identifier"
        },
        "model": {
          "type": "string",
          "description": "Claude model to use"
        },
        "systemPromptOverride": {
          "type": "string",
          "description": "Custom system prompt for this agent"
        },
        "taskTypes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Types of tasks this agent handles"
        },
        "compositionRules": {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "includeKeywords": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      }
    }
  }
}
